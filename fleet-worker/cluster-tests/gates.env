# Acceptance gates for the ITER-0005b cluster verification harness (declarative).
# Sourced by run.sh. Thresholds are in MILLISECONDS unless noted. Derived from the
# STORY-0025 benchmark (nspawn 76ms / Firecracker 1861ms mean, 2134ms p99) plus the
# story ACs (STORY-0017 AC-3 microVM ≤5s; STORY-0008 AC-3 sub-second unit spin-up).
# Tune here, not in run.sh — gates are the iteration's success contract.

# SCENARIO-0029 / STORY-0017 AC-3 — durable microVM boot-to-ready (mean).
GATE_MICROVM_BOOT_MS=5000

# SCENARIO-0004 / STORY-0007 — durable VM stays up across K task cycles (max allowed restarts).
GATE_DURABLE_RESTARTS=0
# SCENARIO-0004 / STORY-0008 AC-3 — in-guest disposable-unit spin-up (p99), warm /nix → sub-second.
GATE_UNIT_SPINUP_P99_MS=1000
# SCENARIO-0004 / STORY-0007 — number of task cycles to prove the durable VM does not restart.
: "${N_DURABLE_CYCLES:=10}"

# SCENARIO-0005 / STORY-0021 — in-guest nspawn --ephemeral fast-tier spin-up (mean), sub-second.
GATE_NSPAWN_SPINUP_MS=1000

# SCENARIO-0006 / STORY-0022 AC-2 — per-task Firecracker hard-tier spin-up (p99): ~1.8s mean +
# headroom over the measured 2134ms p99.
GATE_HARDTIER_SPINUP_P99_MS=2500

# SCENARIO-0007 / STORY-0024 — trust boundary: guest has its own kernel (boolean, 1=pass).
# (no numeric gate; asserted via assert_true)

# STORY-0008 AC-2 — teardown is unit-kill only (no `incus delete` in the hot path); bounded.
GATE_TEARDOWN_MS=5000

# Measurement sample sizes (cluster runs). Env-overridable for quick/dry runs.
: "${N_MICROVM:=20}"
: "${N_NSPAWN:=100}"
: "${N_HARDTIER:=20}"

# --- ITER-0005c image track (golden / skills / provider) ------------------------------
# The golden image alias the image-track scenarios launch copies from (T3 produces it).
: "${FLEET_GOLDEN_IMAGE:=fleet-golden}"
# SCENARIO-0065 / STORY-0075 AC-1 — the realized toolchain a FULL golden must expose on a
# launched copy (substitution-only, no live build). Space-separated binaries.
: "${GOLDEN_TOOLCHAIN:=claude lean-ctx go make git}"
# SCENARIO-0068 / STORY-0077 — curated skill count baked at the discovery path.
GATE_SKILLS_COUNT=13
# SCENARIO-0068 / STORY-0077 — discovery path where claude -p finds bundled skills.
: "${SKILLS_DISCOVERY_PATH:=/etc/claude/skills}"
# SCENARIO-0067 / STORY-0076 — provider CLI BINARIES the golden must export from llm-agents.nix.
# Note: the nixpkgs/llm-agents package names are codex/gemini-cli/qwen-code, but the binaries
# they install are codex/gemini/qwen (verified on the golden).
: "${GOLDEN_PROVIDER_CLIS:=codex gemini qwen}"
# SCENARIO-0069 / STORY-0078 — the flake output that builds the curated skills bundle.
: "${BUNDLE_FLAKE_ATTR:=.#agent-skills-bundle}"
